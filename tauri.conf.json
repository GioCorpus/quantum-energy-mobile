{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Quantum Energy Mobile",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "identifier": "com.quantumenergy.mobile",
    "resources": [],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "Quantum Energy OS Mobile",
    "longDescription": "Mobile interface for Quantum Energy OS with Cuarzo 4D integration"
  },
  "plugins": {
    "battery": {},
    "notification": {}
  }
}
